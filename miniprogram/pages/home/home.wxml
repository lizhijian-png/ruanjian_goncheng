<view class="container">
  <view class="hero-card home-hero">
    <view>
      <view class="tag">推荐流 · 实时任务广场</view>
      <view class="headline">用公开承诺驱动任务完成</view>
      <view class="section-subtitle">{{recommendLabel}}</view>
    </view>
    <button class="primary-btn quick-btn" bindtap="goPublish">发布任务贴</button>
  </view>

  <view class="grid-two score-grid">
    <view class="section-card metric-card">
      <view class="metric-value">{{scoreSummary.points}}</view>
      <view class="muted">当前积分</view>
    </view>
    <view class="section-card metric-card">
      <view class="metric-value">{{scoreSummary.completionRate}}%</view>
      <view class="muted">任务完成率</view>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input
      class="search-input"
      value="{{keyword}}"
      placeholder="搜索标题或发布者…"
      placeholder-class="placeholder"
      bindinput="onSearchInput"
      confirm-type="search"
    />
    <text class="search-clear" wx:if="{{keyword}}" bindtap="clearSearch">✕</text>
  </view>

  <!-- 列表标题 + 筛选按钮 -->
  <view class="list-header">
    <view class="section-title" style="margin-bottom:0">推荐任务贴</view>
    <view class="filter-btn {{filterLabel ? 'filter-btn-active' : ''}}" bindtap="openFilter">
      <text class="filter-icon">⚙</text>
      <text>{{filterLabel || '筛选'}}</text>
    </view>
  </view>

  <!-- 已激活筛选标签 -->
  <view class="active-filter-bar" wx:if="{{filterLabel}}">
    <text class="active-filter-text">{{filterLabel}}</text>
    <text class="active-filter-clear" bindtap="clearAllFilter">✕ 清除</text>
  </view>

  <!-- 帖子列表 -->
  <block wx:for="{{feed}}" wx:key="id">
    <view class="post-card post-item" data-id="{{item.id}}" bindtap="goDetail">
      <view class="post-header">
        <view>
          <view class="post-title">{{item.title}}</view>
          <view class="muted">{{item.publisher}} · {{item.category}} · {{item.status}}</view>
        </view>
        <view class="score-chip">推荐 {{item.recommendedScore}}</view>
      </view>
      <view class="post-content">{{item.content}}</view>
      <view class="post-meta-row">
        <view class="meta-pill">+{{item.reward}} 积分</view>
        <view class="meta-pill danger">-{{item.penalty}} 积分</view>
        <view class="meta-pill">完成度 {{item.progress}}%</view>
      </view>
      <view class="muted small-text" wx:if="{{item.startTime || item.endTime}}">
        {{item.startTime ? '开始：' + item.startTime : ''}}{{item.startTime && item.endTime ? '　' : ''}}{{item.endTime ? '结束：' + item.endTime : ''}}
      </view>
      <view class="muted small-text">聊天：{{item.partnerChat ? '开放' : '可关闭'}}｜互评：{{item.evaluationOpen ? '开放' : '关闭'}}</view>
    </view>
  </block>

  <!-- 底部状态 -->
  <view class="list-footer" wx:if="{{feed.length > 0}}">
    <text wx:if="{{loading}}">加载中…</text>
    <text wx:elif="{{!hasMore}}">已显示全部</text>
  </view>
  <view class="empty-tip" wx:if="{{!loading && feed.length === 0}}">
    <text>暂无符合条件的帖子</text>
  </view>
</view>

<!-- 遮罩 -->
<view class="filter-mask {{filterVisible ? 'mask-visible' : ''}}" bindtap="closeFilter"></view>

<!-- 筛选面板（从底部弹出） -->
<view class="filter-panel {{filterVisible ? 'panel-visible' : ''}}">
  <view class="filter-panel-header">
    <text class="filter-panel-title">筛选条件</text>
    <text class="filter-panel-close" bindtap="closeFilter">×</text>
  </view>

  <!-- 分类 -->
  <view class="filter-section">
    <view class="filter-section-label">任务分类</view>
    <view class="filter-tag-row">
      <view
        class="filter-tag {{draftCategory === '' ? 'filter-tag-active' : ''}}"
        bindtap="onSelectCategory"
        data-value=""
      >全部</view>
      <block wx:for="{{categories}}" wx:key="*this">
        <view
          class="filter-tag {{draftCategory === item ? 'filter-tag-active' : ''}}"
          bindtap="onSelectCategory"
          data-value="{{item}}"
        >{{item}}</view>
      </block>
    </view>
  </view>

  <!-- 时间区间 -->
  <view class="filter-section">
    <view class="filter-section-label">开始时间（不早于）</view>
    <picker mode="date" value="{{draftStartAfter}}" start="{{todayDate}}" bindchange="onStartAfterChange">
      <view class="filter-date-box {{draftStartAfter ? '' : 'placeholder'}}">
        {{draftStartAfter || '不限'}}
      </view>
    </picker>
  </view>

  <view class="filter-section">
    <view class="filter-section-label">结束时间（不晚于）</view>
    <picker mode="date" value="{{draftEndBefore}}" start="{{draftStartAfter || todayDate}}" bindchange="onEndBeforeChange">
      <view class="filter-date-box {{draftEndBefore ? '' : 'placeholder'}}">
        {{draftEndBefore || '不限'}}
      </view>
    </picker>
  </view>

  <!-- 操作按钮 -->
  <view class="filter-actions">
    <button class="ghost-btn filter-action-btn" bindtap="resetFilter">重置</button>
    <button class="primary-btn filter-action-btn" bindtap="applyFilter">应用筛选</button>
  </view>
</view>
