.home-hero {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, rgba(255, 240, 234, 0.96), rgba(236, 248, 255, 0.96));
}

.headline {
  font-size: 48rpx;
  font-weight: 800;
  margin: 18rpx 0 10rpx;
  line-height: 1.2;
}

.quick-btn {
  width: 220rpx;
  height: 86rpx;
  font-size: 28rpx;
}

.score-grid {
  margin-bottom: 20rpx;
}

/* ===== 搜索框 ===== */
.search-bar {
  display: flex;
  align-items: center;
  background: var(--panel);
  border: 1rpx solid rgba(255, 122, 89, 0.18);
  border-radius: 999rpx;
  padding: 0 24rpx;
  height: 76rpx;
  margin-bottom: 24rpx;
  gap: 12rpx;
  box-shadow: var(--shadow-card);
  transition: border-color 0.2s, box-shadow 0.2s;
}

.search-bar:focus-within {
  border-color: var(--primary);
  box-shadow: 0 0 0 3rpx rgba(255, 122, 89, 0.12), var(--shadow-card);
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 76rpx;
  color: var(--text);
}

.search-clear {
  font-size: 28rpx;
  color: #bbb;
  padding: 0 4rpx;
  flex-shrink: 0;
}

.metric-card {
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 245, 247, 0.92));
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.metric-value {
  font-size: 52rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
  background: linear-gradient(135deg, #ff7a59, #ff6b8b);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1.2;
}

/* ===== 列表标题行 ===== */
.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 122, 89, 0.2);
  font-size: 24rpx;
  color: #888;
  max-width: 280rpx;
  overflow: hidden;
  transition: all 0.2s;
}

.filter-btn-active {
  background: rgba(255, 122, 89, 0.10);
  border-color: rgba(255, 122, 89, 0.5);
  color: var(--primary);
  font-weight: 600;
}

.filter-icon {
  font-size: 26rpx;
  flex-shrink: 0;
}

/* ===== 已激活筛选标签 ===== */
.active-filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 122, 89, 0.06);
  border: 1rpx solid rgba(255, 122, 89, 0.12);
  border-radius: var(--radius-sm);
  padding: 14rpx 24rpx;
  margin-bottom: 20rpx;
  animation: fadeIn 0.2s ease;
}

.active-filter-text {
  font-size: 24rpx;
  color: var(--primary);
  flex: 1;
}

.active-filter-clear {
  font-size: 24rpx;
  color: #aaa;
  padding-left: 20rpx;
  flex-shrink: 0;
}

/* ===== 帖子卡片 ===== */
.post-item {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.post-header {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.post-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.score-chip {
  height: fit-content;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 122, 89, 0.14);
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 600;
}

.post-content {
  margin: 18rpx 0;
  line-height: 1.7;
  color: #5a4a52;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.meta-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.12);
  color: #0ea5e9;
  font-size: 22rpx;
  font-weight: 500;
}

.meta-pill.danger {
  background: rgba(244, 63, 94, 0.10);
  color: #e11d48;
}

/* ===== 帖子卡片右侧列（头像 + 推荐分数） ===== */
.post-header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
}

.post-publisher-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
  flex-shrink: 0;
}

/* ===== 筛选遮罩 ===== */
.filter-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s;
}

.filter-mask.mask-visible {
  opacity: 1;
  pointer-events: auto;
}

/* ===== 筛选面板 ===== */
.filter-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: linear-gradient(180deg, #fffaf4, #ffffff);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 36rpx 36rpx calc(48rpx + env(safe-area-inset-bottom));
  z-index: 101;
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.34, 1.2, 0.64, 1);
}

.filter-panel.panel-visible {
  transform: translateY(0);
}

.filter-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 36rpx;
}

.filter-panel-title {
  font-size: 34rpx;
  font-weight: 700;
}

.filter-panel-close {
  font-size: 48rpx;
  color: var(--muted);
  line-height: 1;
  padding: 0 8rpx;
}

/* ===== 筛选区块 ===== */
.filter-section {
  margin-bottom: 32rpx;
}

.filter-section-label {
  font-size: 26rpx;
  color: var(--muted);
  margin-bottom: 16rpx;
  font-weight: 600;
}

/* 分类标签 */
.filter-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-tag {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 122, 89, 0.2);
  background: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  color: #555;
  transition: all 0.15s;
}

.filter-tag:active {
  transform: scale(0.96);
}

.filter-tag-active {
  background: rgba(255, 122, 89, 0.12);
  border-color: var(--primary);
  color: var(--primary);
  font-weight: 700;
}

/* 日期选择 */
.filter-date-box {
  padding: 20rpx 24rpx;
  border-radius: var(--radius-sm);
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 122, 89, 0.18);
  font-size: 28rpx;
  color: var(--text);
}

.filter-date-box.placeholder {
  color: #aaa;
}

/* 操作按钮 */
.filter-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
}

.filter-action-btn {
  flex: 1;
  height: 88rpx;
}

/* ===== 通知弹窗 ===== */
.home-notif-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: rgba(0, 0, 0, 0.85);
  color: #fff;
  padding: 12px 40px 12px 16px;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  animation: slideDown 0.3s ease;
}

.home-notif-inner {
  flex: 1;
  min-width: 0;
}

.home-notif-label {
  font-weight: 700;
  font-size: 13px;
  margin-bottom: 2px;
}

.home-notif-body {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-notif-close {
  flex-shrink: 0;
  margin-left: 12px;
  color: #999;
  padding: 4px;
  font-size: 16px;
}