.home-hero {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, rgba(255, 240, 234, 0.96), rgba(236, 248, 255, 0.96));
}

.headline {
  font-size: 48rpx;
  font-weight: 800;
  margin: 18rpx 0 10rpx;
}

.quick-btn {
  width: 220rpx;
  height: 86rpx;
  line-height: 86rpx;
  font-size: 28rpx;
}

.score-grid {
  margin-bottom: 28rpx;
}

.metric-card {
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 245, 247, 0.92));
}

.metric-value {
  font-size: 52rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
  color: #ff6b8b;
}

.post-item {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.post-header {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.post-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.score-chip {
  height: fit-content;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 122, 89, 0.14);
  color: #ff7a59;
  font-size: 22rpx;
}

.post-content {
  margin: 18rpx 0;
  line-height: 1.7;
}

.post-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.meta-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.12);
  color: #0ea5e9;
  font-size: 22rpx;
}

.meta-pill.danger {
  background: rgba(244, 63, 94, 0.1);
  color: #e11d48;
}

.small-text {
  font-size: 22rpx;
}
