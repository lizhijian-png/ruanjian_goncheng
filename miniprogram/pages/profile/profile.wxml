<view class="container">
  <view class="profile-card profile-header">
    <image class="avatar" src="{{user.avatarUrl}}" mode="aspectFill" />
    <view class="profile-main">
      <view class="profile-name">{{user.nickname}}</view>
      <view class="muted">积分 {{user.points}} · 排名 #{{user.rank}} · 完成率 {{user.completionRate}}%</view>
      <view class="ai-box">
        <view class="tag">AI 评价</view>
        <view class="ai-text">{{user.aiComment}}</view>
      </view>
    </view>
  </view>

  <view class="section-card operations-card">
    <view class="section-title">我的帖子操作</view>
    <button class="primary-btn manage-btn" bindtap="goPublish">继续创建帖子</button>
    <block wx:for="{{posts}}" wx:key="id">
      <view class="post-card my-post">
        <view>
          <view class="post-title">{{item.title}}</view>
          <view class="muted">{{item.status}} · +{{item.reward}} / -{{item.penalty}}</view>
        </view>
        <button class="ghost-btn delete-btn" size="mini" data-id="{{item.id}}" bindtap="deletePost">删除</button>
      </view>
    </block>
  </view>
</view>
