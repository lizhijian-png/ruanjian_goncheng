.profile-header {
  padding: 30rpx;
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, rgba(255, 241, 230, 0.96), rgba(237, 248, 255, 0.96));
}

.avatar {
  width: 136rpx;
  height: 136rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(255, 203, 213, 0.82), rgba(191, 229, 255, 0.88));
  flex-shrink: 0;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.ai-box {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(255, 240, 245, 0.9));
  border: 1rpx solid rgba(255, 122, 89, 0.08);
}

.ai-text {
  margin-top: 14rpx;
  line-height: 1.7;
  font-size: 26rpx;
  color: #5a4a52;
}

.operations-card {
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.9);
}

.manage-btn {
  margin-bottom: 24rpx;
  height: 84rpx;
}

.my-post {
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
  background: linear-gradient(180deg, rgba(255, 249, 245, 0.92), rgba(255, 255, 255, 0.9));
}

.delete-btn {
  min-width: 120rpx;
  font-size: 24rpx;
  height: 60rpx;
}

/* 设置图标（三个竖点） */
.settings-icon {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 12rpx 16rpx;
  align-self: flex-start;
  flex-shrink: 0;
}

.settings-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #8b6f88;
}

/* 弹窗被全局 .bottom-sheet / .mask-overlay 统一接管 */

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
}

.modal-close {
  font-size: 48rpx;
  color: var(--muted);
  line-height: 1;
  padding: 0 8rpx;
}

.modal-section {
  margin-bottom: 32rpx;
}

.modal-label {
  font-size: 26rpx;
  color: var(--muted);
  margin-bottom: 16rpx;
  font-weight: 600;
}

/* 头像选择 */
.avatar-picker {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: rgba(255, 203, 213, 0.4);
}

.avatar-hint {
  font-size: 26rpx;
  color: var(--primary);
}

/* 昵称输入框 */
.modal-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-sm);
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 122, 89, 0.2);
  font-size: 30rpx;
  box-sizing: border-box;
}

.save-btn {
  height: 88rpx;
  margin-top: 12rpx;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: rgba(255, 244, 230, 0.6);
  border-radius: 18rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
  gap: 6rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: var(--muted);
  transition: all 0.2s;
}

.tab-active {
  background: #ffffff;
  color: var(--primary);
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(255, 122, 89, 0.15);
}

/* 帖子卡片内部布局 */
.my-post-main {
  flex: 1;
}

.my-post-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 6rpx;
}

/* 角色标签 */
.role-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.role-tag-publisher {
  background: rgba(139, 111, 136, 0.12);
  color: var(--muted);
}

.role-tag-buddy {
  background: rgba(56, 189, 248, 0.14);
  color: var(--accent);
}

/* 积分行字号 */
.score-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 4rpx;
  font-size: 24rpx;
}

.score-value {
  background: linear-gradient(135deg, #ff8c42, #ff6b8b);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: 800;
  font-size: 32rpx;
}

.score-hint {
  color: var(--primary);
  font-size: 24rpx;
  margin-left: 8rpx;
}

.admin-btn {
  margin: 40rpx auto;
  width: fit-content;
  font-size: 24rpx;
  color: #cbd5e1;
  text-align: center;
  padding: 10rpx 20rpx;
}

.admin-btn:active {
  color: #94a3b8;
}