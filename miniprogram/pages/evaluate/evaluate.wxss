.evidence-card,
.eval-card {
  background: var(--panel);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(16rpx);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.evidence-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text);
}

.empty-hint {
  font-size: 26rpx;
  padding: 8rpx 0;
}

.eval-textarea {
  width: 100%;
  min-height: 180rpx;
  background: rgba(255,250,244,0.9);
  border: 1rpx solid rgba(255,122,89,0.16);
  border-radius: var(--radius-sm);
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.7;
  margin: 14rpx 0 20rpx;
}

.form-btns {
  display: flex;
  gap: 20rpx;
}

.form-btn {
  flex: 1;
  height: 76rpx;
  font-size: 28rpx;
}

.completion-label {
  margin-top: 20rpx;
}

.completion-vote-row {
  display: flex;
  gap: 20rpx;
  margin: 14rpx 0 4rpx;
}

.vote-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: 2rpx solid rgba(255,122,89,0.25);
  color: #64748b;
  background: rgba(255,255,255,0.7);
  transition: all 0.15s;
}

.vote-btn:active {
  transform: scale(0.97);
}

.vote-btn--active-complete {
  background: #dcfce7;
  border-color: #22c55e;
  color: #16a34a;
  font-weight: 600;
}

.vote-btn--active-incomplete {
  background: #fee2e2;
  border-color: #ef4444;
  color: #dc2626;
  font-weight: 600;
}

.vote-btn--disabled {
  opacity: 0.5;
  pointer-events: none;
}

.evidence-img-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.evidence-img-thumb {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-sm);
  background: #f1f5f9;
}

.completion-hint {
  font-size: 24rpx;
  margin-bottom: 20rpx;
}
