/* ===== 页面头部 ===== */
.admin-header {
  padding: 30rpx 32rpx;
  margin-bottom: 28rpx;
  background: linear-gradient(135deg, rgba(255, 240, 234, 0.96), rgba(236, 248, 255, 0.96));
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.admin-header-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text);
}

.admin-header-sub {
  font-size: 24rpx;
  color: var(--muted);
}

/* ===== 帖子列表 ===== */
.post-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.admin-post-card {
  padding: 28rpx;
  margin-bottom: 0;
}

.post-content {
  margin-bottom: 16rpx;
}

.post-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12rpx;
}

.post-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.meta-chip {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(139, 111, 136, 0.08);
  color: var(--muted);
}

.post-time {
  font-size: 22rpx;
  color: var(--muted);
}

.post-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid rgba(255, 122, 89, 0.08);
  padding-top: 16rpx;
}

.audit-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.tag-normal {
  background: rgba(34, 197, 94, 0.10);
  color: #16a34a;
}

.tag-ban {
  background: rgba(244, 63, 94, 0.10);
  color: #e11d48;
}

.toggle-btn {
  margin: 0;
  font-size: 24rpx;
  padding: 6rpx 24rpx;
  height: 60rpx;
  min-width: 140rpx;
}

.btn-warn {
  background: rgba(225, 29, 72, 0.08);
  color: #e11d48;
  border-color: rgba(225, 29, 72, 0.2);
}

.btn-safe {
  background: rgba(34, 197, 94, 0.08);
  color: #16a34a;
  border-color: rgba(34, 197, 94, 0.2);
}