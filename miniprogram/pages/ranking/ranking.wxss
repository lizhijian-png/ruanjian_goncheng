/* ========== 页面头部 ========== */
.page-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 20rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a2e;
  letter-spacing: 2rpx;
}

.page-sub {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 6rpx;
}

/* ========== 领奖台区域 ========== */
.podium-section {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 20rpx 20rpx 0;
  gap: 0;
}

.podium-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

/* 皇冠 */
.crown {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

/* 头像圆圈 */
.podium-avatar-wrap {
  position: relative;
  margin-bottom: 12rpx;
}

.podium-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
}

.podium-avatar-lg {
  width: 120rpx;
  height: 120rpx;
}

/* 名次徽章 */
.podium-badge {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 800;
  color: #fff;
  border: 2rpx solid #fff;
}

.rank-1-badge { background: linear-gradient(135deg, #f7c948, #e8a000); }
.rank-2-badge { background: linear-gradient(135deg, #c0c0c0, #9a9a9a); }
.rank-3-badge { background: linear-gradient(135deg, #cd7f32, #a05c1a); }

.rank-1-wrap .podium-avatar { box-shadow: 0 0 0 4rpx #f7c948, 0 8rpx 24rpx rgba(247,201,72,0.4); }
.rank-2-wrap .podium-avatar { box-shadow: 0 0 0 3rpx #c0c0c0; }
.rank-3-wrap .podium-avatar { box-shadow: 0 0 0 3rpx #cd7f32; }

/* 姓名 */
.podium-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 6rpx;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.podium-name-lg {
  font-size: 28rpx;
}

/* 积分 */
.podium-points {
  font-size: 26rpx;
  font-weight: 800;
  color: #ff7a59;
  margin-bottom: 16rpx;
}

.podium-points-lg {
  font-size: 32rpx;
}

.points-unit {
  font-size: 20rpx;
  font-weight: 400;
  margin-left: 2rpx;
}

/* 台阶方块 */
.podium-block {
  width: 100%;
  border-radius: 12rpx 12rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.podium-block-1 {
  height: 120rpx;
  background: linear-gradient(180deg, #ffe566, #f7c948);
  box-shadow: 0 -4rpx 20rpx rgba(247,201,72,0.4);
}

.podium-block-2 {
  height: 88rpx;
  background: linear-gradient(180deg, #e8e8e8, #c0c0c0);
  box-shadow: 0 -4rpx 16rpx rgba(180,180,180,0.3);
}

.podium-block-3 {
  height: 64rpx;
  background: linear-gradient(180deg, #e8b07a, #cd7f32);
  box-shadow: 0 -4rpx 16rpx rgba(205,127,50,0.3);
}

.podium-rank-label {
  font-size: 32rpx;
}

/* ========== 4名以后列表 ========== */
.list-section {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 8rpx 30rpx 40rpx;
  margin-top: 0;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}

.rank-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.rank-row:last-child {
  border-bottom: none;
}

.rank-row-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.rank-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f5f5f7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #888;
  flex-shrink: 0;
}

.rank-row-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 6rpx;
}

.rank-row-rate {
  font-size: 22rpx;
  color: #aaa;
}

.rank-row-points {
  font-size: 28rpx;
  font-weight: 800;
  color: #ff7a59;
}

.points-unit-sm {
  font-size: 20rpx;
  font-weight: 400;
  margin-left: 2rpx;
}

/* ========== 空状态 ========== */
.empty-tip {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  padding: 80rpx 0;
}

.podium-me {
  outline: 4rpx solid #ff8c42;
  border-radius: 16rpx;
}

.rank-row-me {
  background: #fff3e0;
  border-left: 6rpx solid #ff8c42;
}
