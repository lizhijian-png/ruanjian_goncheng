.ranking-board {
  padding: 30rpx;
  background: linear-gradient(180deg, rgba(255, 250, 244, 0.96), rgba(236, 248, 255, 0.96));
}

.rank-item {
  padding: 24rpx;
  margin-bottom: 18rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.88);
}

.rank-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.rank-index {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(255, 203, 213, 0.9), rgba(255, 236, 224, 0.95));
  color: #ff6b8b;
  font-weight: 800;
}

.rank-name {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.rank-points {
  color: #ff7a59;
  font-weight: 800;
}

.top-rank {
  border: 1rpx solid rgba(255, 122, 89, 0.36);
  box-shadow: 0 12rpx 28rpx rgba(255, 122, 89, 0.12);
}
