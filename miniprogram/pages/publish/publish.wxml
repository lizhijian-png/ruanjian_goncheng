<view class="container">
  <!-- 草稿恢复提示横幅 -->
  <view class="draft-banner" wx:if="{{hasDraft}}">
    <view class="draft-banner-text">检测到未发布的草稿</view>
    <view class="draft-banner-btns">
      <button class="draft-btn draft-btn-secondary" bindtap="discardDraft">丢弃</button>
      <button class="draft-btn draft-btn-primary" bindtap="onDraftConfirm">恢复</button>
    </view>
  </view>

  <view class="form-card publish-card">
    <view class="section-title">发布任务贴</view>
    <view class="section-subtitle">支持设置积分奖惩、搭子聊天、互评开关和证据文本占位。</view>

    <view class="field">
      <view class="label">标题</view>
      <input class="field-input" data-field="title" bindinput="onInput" placeholder="例如：21 天晨跑监督计划" placeholder-class="placeholder" />
    </view>

    <view class="field">
      <view class="label">内容</view>
      <textarea class="field-textarea" data-field="content" bindinput="onInput" placeholder="描述任务规则、完成时间、需要的搭子类型" placeholder-class="placeholder" />
    </view>

    <view class="grid-two">
      <view class="field compact">
        <view class="label">完成奖励</view>
        <input class="field-input" type="number" data-field="reward" bindinput="onInput" value="{{form.reward}}" />
      </view>
      <view class="field compact">
        <view class="label">未完成惩罚</view>
        <input class="field-input" type="number" data-field="penalty" bindinput="onInput" value="{{form.penalty}}" />
      </view>
    </view>

    <view class="field">
      <view class="label">搭子人数上限</view>
      <view class="buddy-limit-row">
        <view class="buddy-limit-btn" bindtap="decMaxBuddies">－</view>
        <view class="buddy-limit-val">{{form.maxBuddies}}</view>
        <view class="buddy-limit-btn" bindtap="incMaxBuddies">＋</view>
        <view class="muted buddy-limit-hint">人满后自动开始任务</view>
      </view>
    </view>

    <view class="field">
      <view class="label">任务分类</view>
      <picker mode="selector" range="{{categories}}" bindchange="onCategoryChange">
        <view class="picker-box">{{form.category}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">开始时间</view>
      <view class="time-row">
        <picker mode="date" value="{{startDate}}" start="{{todayDate}}" bindchange="onStartDateChange">
          <view class="picker-box time-picker {{startDate ? '' : 'placeholder'}}">
            {{startDate || '选择日期'}}
          </view>
        </picker>
        <picker mode="selector" range="{{hours}}" value="{{startHourIndex}}" bindchange="onStartHourChange">
          <view class="picker-box time-picker">{{hours[startHourIndex]}}</view>
        </picker>
      </view>
    </view>

    <view class="field">
      <view class="label">结束时间</view>
      <view class="time-row">
        <picker mode="date" value="{{endDate}}" start="{{startDate || todayDate}}" bindchange="onEndDateChange">
          <view class="picker-box time-picker {{endDate ? '' : 'placeholder'}}">
            {{endDate || '选择日期'}}
          </view>
        </picker>
        <picker mode="selector" range="{{hours}}" value="{{endHourIndex}}" bindchange="onEndHourChange">
          <view class="picker-box time-picker">{{hours[endHourIndex]}}</view>
        </picker>
      </view>
    </view>

    <view class="switch-row">
      <view>
        <view class="label">开放搭子聊天</view>
        <view class="muted">可选功能，便于互相监督</view>
      </view>
      <switch checked="{{form.partnerChat}}" data-field="partnerChat" bindchange="onSwitch" color="#38bdf8" />
    </view>

    <view class="switch-row">
      <view>
        <view class="label">开放互评</view>
        <view class="muted">完成后双方可评分和评价</view>
      </view>
      <switch checked="{{form.evaluationOpen}}" data-field="evaluationOpen" bindchange="onSwitch" color="#f97316" />
    </view>

    <view class="field">
      <view class="label">证据说明</view>
      <textarea class="field-textarea short" data-field="evidenceText" bindinput="onInput" placeholder="例如：需上传截图 + 文字总结，图片上传后续接入云存储" placeholder-class="placeholder" />
    </view>

    <button class="primary-btn submit-btn" bindtap="submitPost">创建并发布</button>
  </view>
</view>
