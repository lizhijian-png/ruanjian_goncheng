.publish-card {
  padding: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 244, 238, 0.92));
}

.field {
  margin-bottom: 24rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.field-input,
.field-textarea,
.picker-box {
  width: 100%;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 122, 89, 0.16);
  border-radius: 24rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
}

.field-textarea {
  min-height: 220rpx;
}

.field-textarea.short {
  min-height: 150rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(255, 122, 89, 0.08);
}

.submit-btn {
  margin-top: 20rpx;
  height: 90rpx;
  line-height: 90rpx;
}
