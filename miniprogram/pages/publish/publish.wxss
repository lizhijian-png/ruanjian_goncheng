/* 草稿恢复横幅 */
.draft-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #fff7ed, #ffedd5);
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(255, 122, 89, 0.2);
}

.draft-banner-text {
  font-size: 26rpx;
  color: #9a3412;
  font-weight: 600;
}

.draft-banner-btns {
  display: flex;
  gap: 16rpx;
}

.draft-btn {
  min-width: 100rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  text-align: center;
}

.draft-btn-primary {
  background: #ff7a59;
  color: #fff;
}

.draft-btn-secondary {
  background: rgba(255, 122, 89, 0.12);
  color: #9a3412;
}

.publish-card {
  padding: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 244, 238, 0.92));
}

.field {
  margin-bottom: 24rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(255, 122, 89, 0.08);
}

.submit-btn {
  margin-top: 20rpx;
  height: 90rpx;
}

.time-row {
  display: flex;
  gap: 16rpx;
}

.time-picker {
  flex: 1;
  font-size: 26rpx;
  text-align: center;
}

.buddy-limit-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.buddy-limit-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(255, 122, 89, 0.12);
  color: var(--primary);
  font-size: 36rpx;
  font-weight: 700;
  transition: background 0.15s, transform 0.15s;
}

.buddy-limit-btn:active {
  background: rgba(255, 122, 89, 0.22);
  transform: scale(0.92);
}

.buddy-limit-val {
  min-width: 60rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
}

.buddy-limit-hint {
  font-size: 22rpx;
}
