.publish-card {
  padding: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 244, 238, 0.92));
}

.field {
  margin-bottom: 24rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.field-input,
.field-textarea,
.picker-box {
  width: 100%;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 122, 89, 0.16);
  border-radius: 24rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
}

.field-textarea {
  min-height: 220rpx;
}

.field-textarea.short {
  min-height: 150rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(255, 122, 89, 0.08);
}

.submit-btn {
  margin-top: 20rpx;
  height: 90rpx;
}

.picker-box.placeholder {
  color: #aaa;
}

.time-row {
  display: flex;
  gap: 16rpx;
}

.time-picker {
  flex: 1;
  font-size: 26rpx;
  text-align: center;
}

.buddy-limit-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.buddy-limit-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(255, 122, 89, 0.12);
  color: var(--primary);
  font-size: 36rpx;
  font-weight: 700;
}

.buddy-limit-val {
  min-width: 60rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
}

.buddy-limit-hint {
  font-size: 22rpx;
}
