page {
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
  background: linear-gradient(180deg, #fffaf4, #f8f0f0);
}

/* ===== 消息列表 ===== */
.message-list {
  flex: 1;
  height: 0;
  overflow: hidden;
  padding: 20rpx 28rpx;
  box-sizing: border-box;
}

.empty-hint {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  margin-top: 80rpx;
}

.msg-row {
  display: flex;
  margin-bottom: 28rpx;
  animation: fadeIn 0.25s ease;
}

.msg-row-self {
  justify-content: flex-end;
}

.bubble {
  max-width: 68%;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  word-break: break-all;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.bubble-other {
  background: #ffffff;
  border: 1rpx solid rgba(200, 190, 190, 0.3);
  border-top-left-radius: 4rpx;
}

.bubble-self {
  background: linear-gradient(135deg, #ff8a66, #ff6b8b);
  color: #ffffff;
  border-top-right-radius: 4rpx;
}

.sender-name {
  font-size: 22rpx;
  color: var(--muted);
  margin-bottom: 8rpx;
  font-weight: 600;
}

.bubble-self .sender-name {
  color: rgba(255, 255, 255, 0.75);
}

.msg-content {
  font-size: 30rpx;
  line-height: 1.6;
}

.msg-time {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
  text-align: right;
}

.bubble-self .msg-time {
  color: rgba(255, 255, 255, 0.65);
}

/* ===== 聊天已关闭横幅 ===== */
.closed-banner {
  text-align: center;
  padding: 20rpx;
  color: #e11d48;
  font-size: 28rpx;
  background: rgba(225, 29, 72, 0.06);
  border-top: 1rpx solid rgba(225, 29, 72, 0.12);
}

/* ===== 输入栏 ===== */
.input-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(240, 232, 224, 0.6);
}

.msg-input {
  flex: 1;
  height: 76rpx;
  background: #f5f0eb;
  border-radius: 38rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  margin-right: 16rpx;
  border: 1rpx solid transparent;
  transition: border-color 0.2s, background 0.2s;
}

.msg-input:focus {
  background: #ffffff;
  border-color: rgba(255, 122, 89, 0.3);
}

.send-btn {
  background: linear-gradient(135deg, #ff8a66, #ff6b8b);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 0 36rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 38rpx;
  min-width: 120rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 139, 0.2);
  transition: opacity 0.15s;
}

.send-btn:active {
  opacity: 0.85;
}

.placeholder {
  color: #bbb;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to   { opacity: 1; transform: translateY(0); }
}