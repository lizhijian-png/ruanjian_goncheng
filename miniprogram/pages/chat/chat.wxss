.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fffaf4;
}

.message-list {
  flex: 1;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
}

.empty-hint {
  text-align: center;
  color: #aaa;
  font-size: 26rpx;
  margin-top: 60rpx;
}

.msg-row {
  display: flex;
  margin-bottom: 24rpx;
}

.msg-row-self {
  justify-content: flex-end;
}

.bubble {
  max-width: 68%;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  word-break: break-all;
}

.bubble-other {
  background: #fff;
  border: 1rpx solid #ede8e8;
}

.bubble-self {
  background: #ff7a59;
  color: #fff;
}

.sender-name {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 6rpx;
}

.msg-content {
  font-size: 30rpx;
  line-height: 1.5;
}

.msg-time {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 6rpx;
  text-align: right;
}

.bubble-self .msg-time {
  color: rgba(255,255,255,0.7);
}

.closed-banner {
  text-align: center;
  padding: 20rpx;
  color: #e11d48;
  font-size: 28rpx;
  background: #fff0f4;
  border-top: 1rpx solid #fcc;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #f0e8e0;
}

.msg-input {
  flex: 1;
  height: 72rpx;
  background: #f5f0eb;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.send-btn {
  background: #ff7a59;
  color: #fff;
  font-size: 28rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  min-width: 120rpx;
}

.placeholder {
  color: #bbb;
}
