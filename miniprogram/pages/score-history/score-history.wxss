/* ===== 页面头部 ===== */
.score-header {
  padding: 30rpx 32rpx;
  margin-bottom: 28rpx;
  background: linear-gradient(135deg, rgba(255, 240, 234, 0.96), rgba(236, 248, 255, 0.96));
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.score-header-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text);
}

.score-header-sub {
  font-size: 24rpx;
  color: var(--muted);
}

/* ===== 列表 ===== */
.log-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.log-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--panel);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(16rpx);
}

.log-icon-wrap {
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
}

.log-icon-plus {
  background: rgba(34, 197, 94, 0.12);
  color: #16a34a;
}

.log-icon-minus {
  background: rgba(244, 63, 94, 0.10);
  color: #e11d48;
}

.log-left {
  flex: 1;
  min-width: 0;
}

.log-reason {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.log-time {
  font-size: 22rpx;
  color: var(--muted);
}

.log-right {
  text-align: right;
  flex-shrink: 0;
}

.log-delta {
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 4rpx;
}

.delta-positive {
  color: #16a34a;
}

.delta-negative {
  color: #e11d48;
}

.log-balance {
  font-size: 22rpx;
  color: var(--muted);
}

/* ===== 空状态/加载 ===== */
.empty-tip {
  text-align: center;
  color: #bbb;
  padding: 100rpx 0;
  font-size: 28rpx;
}