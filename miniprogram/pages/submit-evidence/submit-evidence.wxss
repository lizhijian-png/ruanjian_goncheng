.container {
  padding: 24rpx 24rpx 48rpx;
  background: #fffaf4;
  min-height: 100vh;
}

.card {
  background: var(--panel);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(16rpx);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: #1e293b;
}

.label {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.img-label {
  margin-top: 24rpx;
}

.evidence-textarea {
  width: 100%;
  min-height: 180rpx;
  background: rgba(255,250,244,0.9);
  border: 1rpx solid rgba(255,122,89,0.16);
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.7;
  margin-bottom: 8rpx;
}

.img-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 12rpx 0 28rpx;
}

.img-wrap {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.img-thumb {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255,122,89,0.16);
}

.img-del {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #ef4444;
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
}

.img-add {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  border: 2rpx dashed rgba(255,122,89,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: rgba(255,122,89,0.5);
  background: rgba(255,250,244,0.6);
}

.form-btns {
  display: flex;
  gap: 20rpx;
}

.form-btn {
  flex: 1;
  height: 76rpx;
  font-size: 28rpx;
}
