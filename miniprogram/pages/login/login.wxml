<view class="container login-page">
  <view class="hero-card login-card">
    <view class="tag">微信小程序作业基础框架</view>
    <view class="title">任务搭子 · 积分互助平台</view>
    <view class="desc">围绕发帖、接帖、证据上传、积分奖惩、排行和个人主页构建的校园任务协作小程序。</view>

    <view class="feature-list">
      <block wx:for="{{features}}" wx:key="*this">
        <view class="feature-item">{{item}}</view>
      </block>
    </view>

    <!-- 阶段一：首次进入，只显示微信登录按钮 -->
    <view wx:if="{{!showBindUI}}" class="form-box">
      <button class="primary-btn login-btn" bindtap="handleLogin" loading="{{loading}}">微信登录</button>
    </view>

    <!-- 阶段二：首次用户，补充头像和昵称 -->
    <view wx:else class="form-box">
      <view class="bind-tip">首次登录，请授权头像和昵称</view>

      <view class="avatar-row">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
          <view wx:else class="avatar-placeholder">
            <text class="avatar-placeholder-text">点击选择头像</text>
          </view>
        </button>
      </view>

      <input
        class="nickname-input"
        type="nickname"
        placeholder="点击填写昵称"
        placeholder-class="placeholder"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />

      <button class="primary-btn login-btn" bindtap="handleBind" loading="{{loading}}">完成绑定</button>
    </view>
  </view>
</view>
