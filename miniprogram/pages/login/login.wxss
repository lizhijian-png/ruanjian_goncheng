.login-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
}

.login-card {
  width: 100%;
  padding: 40rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 246, 240, 0.92));
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  margin: 24rpx 0 18rpx;
  line-height: 1.2;
}

.desc {
  color: var(--muted);
  line-height: 1.7;
}

.feature-list {
  margin: 30rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feature-item {
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(255, 236, 224, 0.92), rgba(240, 249, 255, 0.92));
  border: 1rpx solid rgba(255, 122, 89, 0.1);
}

.form-box {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.nickname-input {
  height: 92rpx;
  border-radius: 24rpx;
  padding: 0 28rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 122, 89, 0.16);
}

.placeholder {
  color: #b08992;
}

.login-btn {
  height: 92rpx;
  line-height: 92rpx;
}
