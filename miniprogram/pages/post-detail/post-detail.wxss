.detail-card {
  padding: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 244, 238, 0.92));
}

.detail-title {
  font-size: 42rpx;
  font-weight: 800;
  margin: 18rpx 0 12rpx;
}

.detail-content {
  margin: 22rpx 0;
  line-height: 1.8;
}

.detail-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.detail-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.12);
  color: #0ea5e9;
}

.detail-chip.danger {
  background: rgba(244, 63, 94, 0.1);
  color: #e11d48;
}

.detail-section {
  margin-top: 28rpx;
}

.evidence-item,
.evaluation-item {
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 122, 89, 0.1);
  margin-bottom: 16rpx;
}

.evaluation-head {
  font-weight: 700;
  margin-bottom: 8rpx;
}

.judge-btn {
  margin-bottom: 20rpx;
  height: 84rpx;
  line-height: 84rpx;
}
