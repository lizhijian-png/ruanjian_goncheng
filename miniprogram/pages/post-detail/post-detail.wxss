.detail-card {
  padding: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 244, 238, 0.92));
}

.detail-title {
  font-size: 42rpx;
  font-weight: 800;
  margin: 18rpx 0 12rpx;
}

.detail-content {
  margin: 22rpx 0;
  line-height: 1.8;
}

.detail-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.detail-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.12);
  color: #0ea5e9;
}

.detail-chip.danger {
  background: rgba(244, 63, 94, 0.1);
  color: #e11d48;
}

.detail-section {
  margin-top: 28rpx;
}

.evidence-item,
.evaluation-item {
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 122, 89, 0.1);
  margin-bottom: 16rpx;
}

.evaluation-head {
  font-weight: 700;
  margin-bottom: 8rpx;
}

.buddy-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 122, 89, 0.1);
  margin-bottom: 12rpx;
}

.buddy-name {
  font-weight: 600;
  font-size: 28rpx;
}

.buddy-time {
  font-size: 22rpx;
}

.action-area {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin: 28rpx 0 8rpx;
}

.action-btn {
  height: 84rpx;
}

.empty-hint {
  font-size: 26rpx;
  padding: 16rpx 0 20rpx;
}

.evidence-form {
  margin-top: 16rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 122, 89, 0.18);
  border-radius: 22rpx;
}

.evidence-textarea {
  width: 100%;
  min-height: 180rpx;
  background: rgba(255, 250, 244, 0.9);
  border: 1rpx solid rgba(255, 122, 89, 0.16);
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.7;
  margin: 14rpx 0 20rpx;
}

.evidence-form-btns {
  display: flex;
  gap: 20rpx;
}

.evidence-btn {
  flex: 1;
  height: 76rpx;
  font-size: 28rpx;
}

.judge-btn {
  margin-bottom: 20rpx;
  height: 84rpx;
}

.danger-btn {
  margin-bottom: 20rpx;
  background: rgba(225, 29, 72, 0.08);
  color: #e11d48;
  border: 1rpx solid rgba(225, 29, 72, 0.25);
  border-radius: 999rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
}

.eval-done-hint {
  text-align: center;
  font-size: 26rpx;
  color: #f97316;
  padding: 16rpx 0;
}

.eval-form {
  margin-top: 16rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(249, 115, 22, 0.2);
  border-radius: 22rpx;
}

.eval-score-row {
  margin: 14rpx 0 8rpx;
}

.eval-slider {
  margin-top: 8rpx;
}

/* ===== Publisher bar ===== */
.publisher-bar {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  margin: 12rpx 0 18rpx;
}

.publisher-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
  flex-shrink: 0;
}

.publisher-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.publisher-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}

.publisher-category {
  font-size: 22rpx;
  color: var(--muted);
}
