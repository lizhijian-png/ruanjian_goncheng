<view class="layer-root">
  <view
    wx:for="{{items}}"
    wx:key="id"
    class="anno {{item.type === 'stamp' ? 'anno-stamp' : 'anno-text'}}"
    style="left:{{item.x}}%;top:{{item.y}}%;{{item.cssStyle}}"
    data-id="{{item.id}}"
    catchtap="onTapAnnotation"
  >{{item.content}}</view>
</view>
