:root {
  --bg: #fffaf4;
  --panel: rgba(255, 255, 255, 0.92);
  --panel-soft: rgba(255, 244, 230, 0.82);
  --line: rgba(244, 114, 182, 0.16);
  --text: #3b2240;
  --muted: #8b6f88;
  --primary: #ff7a59;
  --accent: #38bdf8;
  --success: #22c55e;
  --danger: #f43f5e;
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --shadow-card: 0 8rpx 32rpx rgba(255, 122, 89, 0.10);
  --shadow-btn: 0 8rpx 20rpx rgba(255, 107, 139, 0.20);
  --shadow-elevated: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
}

page {
  background:
    radial-gradient(circle at top left, rgba(255, 122, 89, 0.18), transparent 26%),
    radial-gradient(circle at top right, rgba(56, 189, 248, 0.16), transparent 28%),
    radial-gradient(circle at bottom left, rgba(250, 204, 21, 0.14), transparent 25%),
    linear-gradient(180deg, #fffaf4 0%, #fff1f2 52%, #eef9ff 100%);
  color: var(--text);
  min-height: 100%;
  font-family: "Microsoft YaHei", "PingFang SC", sans-serif;
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}

.container {
  padding: 32rpx;
}

/* ===== 卡片统一体系 ===== */
.hero-card,
.section-card,
.post-card,
.rank-card,
.profile-card,
.form-card {
  background: var(--panel);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(16rpx);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-subtitle,
.muted {
  color: var(--muted);
}

/* ===== 标签 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 122, 89, 0.14);
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

/* ===== 按钮体系 ===== */
.primary-btn {
  background: linear-gradient(135deg, #ff8a66, #ff6b8b);
  color: #ffffff;
  border: none;
  border-radius: 999rpx;
  font-weight: 700;
  box-shadow: var(--shadow-btn);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
  transition: opacity 0.15s, transform 0.15s;
}

.primary-btn:active {
  opacity: 0.88;
  transform: scale(0.97);
}

.ghost-btn {
  background: rgba(255, 255, 255, 0.72);
  color: var(--text);
  border: 1rpx solid rgba(255, 122, 89, 0.18);
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
  transition: background 0.15s, border-color 0.15s;
}

.ghost-btn:active {
  background: rgba(255, 122, 89, 0.08);
  border-color: rgba(255, 122, 89, 0.3);
}

.danger-btn {
  background: rgba(225, 29, 72, 0.08);
  color: #e11d48;
  border: 1rpx solid rgba(225, 29, 72, 0.25);
  border-radius: 999rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
  transition: background 0.15s;
}

.danger-btn:active {
  background: rgba(225, 29, 72, 0.15);
}

/* ===== 网格 ===== */
.grid-two {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

/* ===== 输入框统一 ===== */
.field-input,
.field-textarea,
.picker-box,
.modal-input {
  width: 100%;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 122, 89, 0.16);
  border-radius: var(--radius-md);
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.field-input:focus,
.field-textarea:focus,
.picker-box:focus,
.modal-input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 3rpx rgba(255, 122, 89, 0.12);
}

/* ===== 表单标签 ===== */
.label {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
  color: var(--text);
}

/* ===== 空状态 ===== */
.empty-tip {
  text-align: center;
  font-size: 26rpx;
  color: #bbb;
  padding: 80rpx 0;
}

/* ===== 底部加载状态 ===== */
.list-footer {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  padding: 24rpx 0 40rpx;
}

/* ===== 遮罩统一 ===== */
.mask-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
}

.mask-overlay.mask-visible {
  opacity: 1;
  pointer-events: auto;
}

/* ===== 底部面板弹窗统一 ===== */
.bottom-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: linear-gradient(180deg, #fffaf4, #ffffff);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 36rpx 36rpx calc(48rpx + var(--safe-bottom));
  z-index: 101;
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.34, 1.2, 0.64, 1);
}

.bottom-sheet.sheet-visible {
  transform: translateY(0);
}

/* ===== placeholder 样式 ===== */
.placeholder {
  color: #b08992;
}

/* ===== 小文本 ===== */
.small-text {
  font-size: 22rpx;
}

/* ===== 关键帧动画 ===== */
@keyframes slideDown {
  from { transform: translateY(-100%); }
  to   { transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.92); }
  to   { opacity: 1; transform: scale(1); }
}