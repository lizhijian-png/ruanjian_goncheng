@startuml
left to right direction

actor "普通用户/搭子" as User
actor "任务发起方" as Initiator
actor "系统管理员" as Admin

' 语义上使用 <|-- 表示继承
Initiator <|-- User

package "账号与主页模块" {
  usecase "微信一键授权注册/登录" as UC1
  usecase "修改个人昵称与头像" as UC2
  usecase "查看AI智能评价" as UC3
}

package "帖子大厅与流转模块" {
  usecase "发布任务贴" as UC4
  usecase "确认完成 / 放弃任务" as UC5
  usecase "列表查询与过滤" as UC6
  usecase "加入 / 退出任务" as UC7
  usecase "上传任务执行证据" as UC8
  usecase "任务结束后双向打分" as UC9
}

' 连线部分
User --> UC1
User --> UC2
User --> UC3
User --> UC6
User --> UC7
User --> UC8
User --> UC9

Initiator --> UC4
Initiator --> UC5

Admin --> (管理员专属口令登录)
Admin --> (查看全量列表)
Admin --> (标记违规任务 / 修改审核状态)

@enduml