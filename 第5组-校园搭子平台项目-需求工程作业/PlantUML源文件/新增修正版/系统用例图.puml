@startuml
left to right direction
actor "普通用户/搭子" as User
actor "任务发起方" as Initiator
actor "系统管理员" as Admin

Initiator |> User

package "账号与主页模块" {
  User --> (微信一键授权注册/登录)
  User --> (修改个人昵称与头像)
  User --> (查看AI智能评价)
}

package "帖子大厅与流转模块" {
  Initiator --> (发布任务贴)
  Initiator --> (手动确认完成 / 放弃任务)
  User --> (列表查询与个性化过滤)
  User --> (加入 / 退出招募中任务)
  User --> (上传任务执行证据)
  User --> (任务结束后双向打分评价)
}

package "积分与推荐模块" {
  User --> (查看系统实时积分排行榜)
  User --> (获取千人千面的动态推荐分)
}

package "后台管理模块" {
  Admin --> (管理员专属口令登录)
  Admin --> (查看包含隐藏记录的全量列表)
  Admin --> (标记违规任务 / 修改审核状态)
}
@enduml