@startuml
' 设置全局字体以避免中文乱码（取决于你的系统字体）
skinparam defaultFontName "Microsoft YaHei"
skinparam packageStyle rectangle

package "前端 (微信小程序客户端)" {
  class 页面视图 {
    +广场页 (Feed)
    +帖子详情页 (PostDetail)
    +个人主页 (Profile)
    +管理后台 (Admin)
  }
  class API请求层 <<api.js>> {
    +getFeed()
    +createPost()
    +submitEvidence()
    +adminLogin()
  }
}

package "后端 (Node.js / Express)" {
  class Auth路由模块
  class Post路由模块
  class User路由模块
  class 数据库服务 <<db.js>> {
    +query()
    +withTransaction()
  }
}

package "数据模型 (MySQL)" {
  entity Users {
    *id (主键)
    --
    openid
    points
  }
  entity Posts {
    *id (主键)
    --
    publisherId
    status
  }
}

' 优化连线逻辑
页面视图 --> API请求层
API请求层 --> Auth路由模块
API请求层 --> Post路由模块
API请求层 --> User路由模块

Auth路由模块 --> 数据库服务
Post路由模块 --> 数据库服务
User路由模块 --> 数据库服务

数据库服务 --> Users
数据库服务 --> Posts
@enduml